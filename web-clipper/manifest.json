{
  "manifest_version": 3,
  "name": "Ktree 剪藏",
  "version": "0.1.0",
  "description": "把网页正文或选区剪藏到 Ktree 知识库,自动转 Markdown 并入库。",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "剪藏到 Ktree"
  }
}
