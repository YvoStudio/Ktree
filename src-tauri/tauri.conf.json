{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ktree",
  "version": "0.1.0",
  "identifier": "studio.yvo.ktree",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ktree 设置",
        "width": 720,
        "height": 640,
        "minWidth": 560,
        "minHeight": 440,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": false,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/convert",
      "binaries/feishu-sync"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/YvoStudio/Ktree/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJEM0ZDNEQ4ODlGQ0I0QUUKUldTdXRQeUoyTVEvdlZrcGZSQ2NsUWVTV1lYMWRxVlBucDlyMFZXZEN5ZHQrWTlhQ3JTRlYrU3IK"
    }
  }
}
